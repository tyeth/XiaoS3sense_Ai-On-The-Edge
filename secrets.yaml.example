# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored so your credentials stay out of the repo.

# --- Wi-Fi (two networks, priority order) ---
wifi_ssid_1: "your-ssid"
wifi_password_1: "your-wifi-password"
wifi_ssid_2: "backup-ssid"
wifi_password_2: "backup-wifi-password"

# Password for the fallback captive-portal hotspot.
fallback_hotspot_password: "meter-ocr-hotspot"

# --- MQTT broker (for Home Assistant discovery) ---
# The broker host — usually the same machine as Home Assistant. This is NOT the
# HA web UI URL (https://homeassistant.gdenu.fi:8123); MQTT uses port 1883.
mqtt_broker: "homeassistant.gdenu.fi"
mqtt_username: "mqtt-user"
mqtt_password: "mqtt-password"
