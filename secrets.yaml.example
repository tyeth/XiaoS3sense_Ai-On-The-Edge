# Copy this file to secrets.yaml and fill in your values (CLI / Option B).
# secrets.yaml is git-ignored so your credentials stay out of the repo.
#
# In the ESPHome Builder (Option A) these live in the Builder's own Secrets
# editor instead — and only wifi_ssid / wifi_password are actually required.

# --- Wi-Fi (standard ESPHome secret names) ---
wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

# --- MQTT broker (optional; only if you set the mqtt_* substitutions to
#     !secret values instead of the plaintext defaults in config.yaml) ---
# mqtt_username: "mqtt-user"
# mqtt_password: "mqtt-password"
